# ─────────────────────────────────────────────────────────────────────────────
# Career-OS Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Adzuna API (REQUIRED for live job data) ───────────────────────────────────
# Register free at: https://developer.adzuna.com/signup
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ── Cache TTL (seconds) — default 24h ────────────────────────────────────────
# Live Adzuna data is cached for 6h regardless of this value.
# This controls the default for any other cached data.
CACHE_TTL=86400

# ── Legacy API keys (no longer used — kept for reference) ────────────────────
# LINKEDIN_API_KEY=
# INDEED_API_KEY=
# GLASSDOOR_API_KEY=
# NAUKRI_API_KEY=
# EUROJOBS_API_KEY=
# OPENAI_API_KEY=

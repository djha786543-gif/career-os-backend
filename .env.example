# ──────────────────────────────────────────────────────────────
# Career-OS Backend — Environment Variables Example
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Adzuna API (REQUIRED for live job data)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Server
PORT=4000

# Cache TTL (seconds) — default 24h
CACHE_TTL=86400

# Puppeteer/Chromium (optional)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Legacy API keys (no longer used)
# LINKEDIN_API_KEY=
# INDEED_API_KEY=
# GLASSDOOR_API_KEY=
# NAUKRI_API_KEY=
# EUROJOBS_API_KEY=
# OPENAI_API_KEY=
